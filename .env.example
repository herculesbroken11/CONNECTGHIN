# Copy to apps/api/.env and apps/admin/.env.local as needed

# Database
DATABASE_URL=postgresql://connectghin:connectghin@localhost:5432/connectghin?schema=public

# Redis (rate limit / cache)
REDIS_URL=redis://localhost:6379

# API
NODE_ENV=development
API_PORT=3000
API_GLOBAL_PREFIX=api/v1

# JWT
JWT_ACCESS_SECRET=change-me-access-min-32-chars-long-secret
JWT_REFRESH_SECRET=change-me-refresh-min-32-chars-long-secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# App URLs
APP_PUBLIC_URL=http://localhost:3000
ADMIN_PUBLIC_URL=http://localhost:3001

# Stripe
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
STRIPE_PRICE_MONTHLY_PREMIUM=price_xxx
STRIPE_TRIAL_DAYS=7

# Storage (S3-compatible; optional for local — use local disk if unset)
S3_ENDPOINT=
S3_REGION=us-east-1
S3_BUCKET=connectghin-uploads
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_PUBLIC_BASE_URL=

# Firebase (FCM server key / service account path)
FIREBASE_SERVICE_ACCOUNT_PATH=

# CORS
CORS_ORIGINS=http://localhost:3001,http://localhost:8080
