<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!--
      Dev HTTP to the host machine from an Android emulator.
      See https://developer.android.com/studio/run/emulator-networking
      and https://medium.com/livefront/how-to-connect-your-android-emulator-to-a-local-web-service-47c380bff350
    -->
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="false">10.0.2.2</domain>
        <domain includeSubdomains="false">127.0.0.1</domain>
        <domain includeSubdomains="false">localhost</domain>
    </domain-config>
</network-security-config>
